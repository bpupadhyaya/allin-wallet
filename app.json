{
  "expo": {
    "name": "AllIn Wallet",
    "slug": "allin-wallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "allinwallet",
    "userInterfaceStyle": "dark",
    "platforms": ["ios", "android"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.allinwallet.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to unlock your wallet"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.allinwallet.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID to unlock your wallet"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow AllIn Wallet to use the camera to scan WalletConnect QR codes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "devMode": true
    }
  }
}
