# ─── AllIn Wallet — environment variables ────────────────────────────────────
# Copy this file to .env and fill in your values.
# Variables prefixed with EXPO_PUBLIC_ are bundled into the app (non-secret).
# Never put private keys or server-side secrets here.

# ── RPC endpoints ─────────────────────────────────────────────────────────────
# Defaults work for development but rate-limit on mainnet.
# Get dedicated endpoints at: https://infura.io, https://alchemy.com, https://quicknode.com
EXPO_PUBLIC_ETH_RPC=https://eth.llamarpc.com
EXPO_PUBLIC_SOL_RPC=https://api.mainnet-beta.solana.com
EXPO_PUBLIC_BTC_API=https://mempool.space/api

# ── Li.Fi (cross-chain swaps: ETH ↔ SOL, all EVM bridges) ───────────────────
# Register at: https://li.fi/sdk — free tier available
EXPO_PUBLIC_LIFI_API_KEY=

# ── WalletConnect v2 (dApp connectivity) ─────────────────────────────────────
# Register at: https://cloud.walletconnect.com — free tier available
# Without this, WalletConnect tab will show "disabled" but the rest of the app works.
EXPO_PUBLIC_WC_PROJECT_ID=
